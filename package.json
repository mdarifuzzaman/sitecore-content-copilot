{
  "name": "sitecore-content-copilot",
  "displayName": "Sitecore Content Copilot",
  "description": "Developer toolkit for Sitecore XM Cloud and Headless development.",
  "version": "0.1.0",
  "publisher": "arif-dev",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other",
    "Programming Languages"
  ],
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/mdarifuzzaman/sitecore-content-copilot"
  },
  "activationEvents": [
    "onCommand:sitecore.previewRoute",
    "onCommand:sitecore.generateModel"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "sitecoreCopilot.endpoint": {
        "type": "string",
        "default": "",
        "description": "Sitecore GraphQL endpoint"
      },
      "sitecoreCopilot.apiKey": {
        "type": "string",
        "default": "",
        "description": "Sitecore API key"
      },
      "sitecoreCopilot.language": {
        "type": "string",
        "default": "en",
        "description": "Sitecore language"
      },
      "sitecoreCopilot.aiEnabled": {
        "type": "boolean",
        "default": false,
        "description": "Enable AI features in Sitecore Content Copilot"
      },      
      "sitecoreCopilot.aiApiKey": {
        "type": "string",
        "default": "",
        "description": "API key for AI endpoint"
      },
      "sitecoreCopilot.aiModel": {
        "type": "string",
        "default": "",
        "description": "Model name for AI requests"
      }
    },
    "commands": [
    {
      "command": "sitecore.connect",
      "title": "Sitecore: Connect"
    },
    {
      "command": "sitecore.searchItem",
      "title": "Sitecore: Search Item"
    },
    {
      "command": "sitecore.refreshExplorer",
      "title": "Sitecore: Refresh Explorer"
    },
    {
    "command": "sitecore.openItemFromExplorer",
    "title": "Sitecore: Open Item From Explorer"
    },
    {
      "command": "sitecore.generateTypes",
      "title": "Sitecore: Generate TypeScript Model"
    },
    {
      "command": "sitecore.generateJssModel",
      "title": "Sitecore: Generate JSS Field Model"
    },
    {
      "command": "sitecore.copyGraphqlQuery",
      "title": "Sitecore: Copy GraphQL Query"
    },
    {
      "command": "sitecore.openGraphqlExplorer",
      "title": "Sitecore: Open GraphQL Explorer"
    },
    {
      "command": "sitecore.generateComponent",
      "title": "Sitecore: Generate JSS Component"
    },
    {
      "command": "sitecore.openItemInGraphqlExplorer",
      "title": "Sitecore: Open Item in GraphQL Explorer"
    },
    {
      "command": "sitecore.explainItem",
      "title": "Sitecore: Explain Item"
    }
  ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sitecoreCopilot",
          "title": "Sitecore",
          "icon": "media/sitecore.svg"
        }
      ]
    },
    "views": {
      "sitecoreCopilot": [
        {
          "id": "sitecoreExplorer",
          "name": "Content Copilot"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "sitecore.refreshExplorer",
          "when": "view == sitecoreExplorer",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "sitecore.openItemFromExplorer",
          "when": "view == sitecoreExplorer && viewItem == item",
          "group": "inline"
        },
        {
          "command": "sitecore.generateTypes",
          "when": "view == sitecoreExplorer && viewItem == item",
          "group": "navigation@1"
        },
        {
          "command": "sitecore.generateJssModel",
          "when": "view == sitecoreExplorer && viewItem == item",
          "group": "navigation@2"
        },
        {
          "command": "sitecore.copyGraphqlQuery",
          "when": "view == sitecoreExplorer && viewItem == item",
          "group": "navigation@3"
        },
        {
          "command": "sitecore.generateComponent",
          "when": "view == sitecoreExplorer && viewItem == item",
          "group": "navigation@4"
        },
        {
          "command": "sitecore.openItemInGraphqlExplorer",
          "when": "view == sitecoreExplorer && viewItem == item",
          "group": "navigation@5"
        },
        {
          "command": "sitecore.explainItem",
          "when": "view == sitecoreExplorer && viewItem == item",
          "group": "navigation@6"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.15",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
